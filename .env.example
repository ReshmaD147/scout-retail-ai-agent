# Copy this file to .env and adjust values as needed.
# .env is git-ignored and must never be committed.

APP_NAME=Retail AI Assistant (Scout)
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_PATH=data/scout.db
NEARBY_STORE_RADIUS_MILES=25.0
MAX_SEARCH_RADIUS_MILES=100.0
STANDARD_DELIVERY_MIN_DAYS=3
STANDARD_DELIVERY_MAX_DAYS=5
MAX_WORKFLOW_STEPS=25
MAX_RETRIES=3
MAX_CORRECTION_ATTEMPTS=2
SCOUT_WORKFLOW_TIMEOUT_SECONDS=20.0
SCOUT_STREAM_HEARTBEAT_SECONDS=15.0
CORS_ALLOWED_ORIGINS=http://localhost:5173
MAX_CART_ITEM_QUANTITY=10
CHECKOUT_TAX_RATE=0.08
FLAT_SHIPPING_FEE=5.99
FREE_SHIPPING_THRESHOLD=50.00
CHECKOUT_CURRENCY=USD
MOCK_PAYMENT_PROVIDER=mock
EMBEDDING_PROVIDER=hashing
EMBEDDING_DIMENSIONS=256
SEMANTIC_SEARCH_CANDIDATE_LIMIT=20
SEMANTIC_SEARCH_MIN_SIMILARITY=0.0
MAX_RECOMMENDED_PRODUCTS=3
MAX_EXTERNAL_OFFERS=3

# Step 17 read-only order-status policy
ORDER_PICKUP_READY_MINUTES=120
ORDER_CANCELLATION_WINDOW_MINUTES=60
ORDER_RETURN_WINDOW_DAYS=30
ORDER_EXCHANGE_WINDOW_DAYS=30
